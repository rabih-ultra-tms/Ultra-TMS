#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Scan staged changes for leaked secrets (gitleaks)
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --config .gitleaks.toml --verbose
  if [ $? -ne 0 ]; then
    echo "gitleaks: secrets detected in staged files. Commit blocked."
    exit 1
  fi
else
  echo "WARNING: gitleaks not installed — skipping secret scan. Install: https://github.com/gitleaks/gitleaks#installing"
fi

pnpm lint-staged
