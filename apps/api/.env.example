# REQUIRED - Application will not start without these
JWT_SECRET=your-secure-jwt-secret-min-32-chars
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tms_dev
REDIS_URL=redis://localhost:6379

# Environment
NODE_ENV=development
PORT=3001

# Logging (INFRA-002)
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# Elasticsearch
ELASTIC_NODE=http://localhost:9200
ELASTIC_NAME_PREFIX=ultra
ELASTIC_MAX_RETRIES=3
ELASTIC_REQUEST_TIMEOUT=10000

# RATE LIMITING (optional - uses defaults if not set)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# REQUIRED FOR PORTALS - Will fail if portal modules are used
CUSTOMER_PORTAL_JWT_SECRET=your-customer-portal-secret
CARRIER_PORTAL_JWT_SECRET=your-carrier-portal-secret

# CORS (comma-separated origins, defaults to localhost:3000,3002)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Encryption (required in production, optional in dev)
ENCRYPTION_KEY=                    # 64-char hex string (generate: openssl rand -hex 32)

# HubSpot webhook signature verification (required in production)
HUBSPOT_CLIENT_SECRET=              # HubSpot app client secret for webhook signature verification

# File Storage (default: local filesystem)
STORAGE_DRIVER=local                  # local | s3
STORAGE_LOCAL_PATH=./uploads          # local driver: directory path
STORAGE_PUBLIC_URL=http://localhost:3001/uploads  # local driver: public URL base

# AWS S3 (required when STORAGE_DRIVER=s3)
AWS_S3_BUCKET=                        # S3 bucket name
AWS_S3_REGION=us-east-1               # AWS region
AWS_ACCESS_KEY_ID=                    # AWS credentials (omit to use IAM role / default chain)
AWS_SECRET_ACCESS_KEY=
AWS_S3_PREFIX=                        # Optional key prefix (e.g. "uploads/")
AWS_S3_ENDPOINT=                      # Optional: custom endpoint for MinIO / R2 / LocalStack
AWS_S3_FORCE_PATH_STYLE=false         # Set true for MinIO / LocalStack

# Error Tracking (INFRA-004) — install @sentry/node to enable
SENTRY_DSN=

# OPTIONAL - Gracefully disabled if not set
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
